# 复制为 .env 并填写。切勿提交 .env（已在 .gitignore 中忽略）。

# ---------- LLM Provider 密钥（按所用 provider 填写，示例为 DeepSeek） ----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---------- 网关 OpenAI 兼容 API(8642) ----------
# 默认关闭；设置下面两项才会启动 API 服务器。
# API_SERVER_HOST 已在 docker-compose.yaml 中设为 0.0.0.0，这里只需给 KEY。
API_SERVER_KEY=change-me-to-a-random-string
