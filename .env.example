# 复制为 .env 并填写。切勿提交 .env（已在 .gitignore 中忽略）。

# ---------- LLM Provider 密钥（按所用 provider 填写，示例为 DeepSeek） ----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---------- Dashboard(9119) 登录用户名/密码 ----------
# 两种部署（docker-compose.yaml 与 docker-compose.https.yaml）都用这组凭据登录。
# 新版镜像要求 dashboard 必须有认证才能对外绑定。
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-to-a-strong-password

# ---------- 网关 OpenAI 兼容 API(8642) ----------
# compose 已设 API_SERVER_HOST=0.0.0.0，这里给访问令牌即可开启。
API_SERVER_KEY=change-me-to-a-random-string

# ---------- 仅 HTTPS 部署需要（docker-compose.https.yaml） ----------
# 你的域名：需解析到本机公网 IP，且 80/443 可从公网访问以完成 ACME HTTP-01 挑战。
DOMAIN=hermes.example.com
# ACME/Let's Encrypt 证书通知邮箱。
ACME_EMAIL=you@example.com
