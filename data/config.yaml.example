# 复制为 data/config.yaml。挂载在容器 /opt/data/config.yaml。

# ---------- Provider / 模型（示例：DeepSeek） ----------
provider: deepseek
model: deepseek-chat

# ---------- Dashboard 认证 ----------
# 无需在此配置 basic_auth：用户名/密码已通过 .env 的
# DASHBOARD_USERNAME / DASHBOARD_PASSWORD（→ HERMES_DASHBOARD_BASIC_AUTH_*）设置，
# 由内置 basic provider 处理，无需手动生成 password_hash。
